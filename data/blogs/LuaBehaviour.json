        },
        { "type": "header", "level": 2, "data": "XLua的引入以及问题的产生" },
        {
            "type": "text",
            "data": [
                "引入XLua后，我们可以通过在预制体上挂载LuaBehaviour组件，再将Lua脚本绑定到LuaBehaviour组件上，使得可以针对某一个游戏对象使用Lua控制，这一块可以参考XLua官方repo的教程。但是也有需要像Unity组件那样进行序列化设置初始值的时候，那么接下来就介绍方法。"
            ]
        },
        { "type": "header", "level": 3, "data": "思路" },
        {
            "type": "text",
            "data": [
                "1. 使用XLua框架的LuaTable、LuaFunction和smilehao提供框架中的BaseClass实现",
                "2. BaseClass用于继承一些函数，不至于每个脚本都写一些相同的逻辑",
                "3. LuaTable用于获取Lua脚本的函数、变量、变量类型等参数",
                "4. 通过LuaTable表中我们设置的变量名称以及变量类型，继承自UnityEngine.Object的类型如GameObject、Transform等就使用UnityEngine.Object进行序列化，使用EditorGUILayout.ObjectField进行绘制",
                "5. 而一些值类型如int，float、Vector3使用字符串进行序列化，但是使用的Unity提供的JsonUtility进行序列化，保证稳定性"
            ]
        },
        { "type": "header", "level": 3, "data": "脚本" },
        { "type": "header", "level": 4, "data": "LuaBehaivour.lua" },
        {
            "type": "text",
            "data": [
                "1. 新建LuaBehaviour.lua，使用BaseClass写一个LuaBehaivour类，而其他类继承自这个类后通过规定的函数（此处为__Define）进行变量与类的定义"
            ]
        },
        {
            "type": "code",
            "data": [
                "local Class = require(\"Core.Class\")",
                "local LuaBehaviour = Class(\"LuaBehaviour\")",
                "",
                "local function CallDefine(classType, defineSelf)",
                "\tif classType.super then",
                "\t\tCallDefine(classType.super, defineSelf)",
                "\tend",
                "\t--- 派生类中定义变量与变量类型的函数",
                "\tif classType.__Define then",
                "\t\tclassType.__Define(defineSelf)",
                "\tend",
                "end",
                "",
                "local defineSelf = {}",
                "local defineStore = {}",
                "-- 保证C#端的LuaTable中变量顺序",
                "setmetatable(defineSelf, {__newindex = function(_ , n, t)",
                "\ttable.insert(defineStore, {name = n, type= t})",
                "end})",
                "",
                "local function _ClearLocalDefineList()",
                "\tfor i = 1, #defineStore do",
                "\t\tdefineStore[i] = nil",
                "\tend",
                "end",
                "",
                "function LuaBehaviour:Define()",
                "\t--这个 define 可能会多次被调用。 只执行一次即可",
                "\tif rawget(self, \"_DefineList\") ~= nil then return end",
                "\t_ClearLocalDefineList()",
                "\tself._DefineList = {}",
                "",
                "\tCallDefine(self, defineSelf)",
                "\tfor key, value in ipairs(defineStore) do",
                "\t\ttable.insert(self._DefineList, { name = value.name, type = value.value})",
                "\tend",
                "end",
                "",
                "return LuaBehaviour"
            ]
        },
        {
            "type": "text",
            "data": [
                "2. 在C#脚本中调用上述的Define函数，就会生产一个_DefineList，这个_DefineList中就存储了需要序列化的变量名称和变量类型，并且是按照自己写的顺序排序的"
            ]
        },
        { "type": "header", "level": 4, "data": "派生类的__Define函数" },
        {
            "type": "code",
            "data": [
                "local CSType = require(\"Core.CSType\")",
                "local Class = require(\"Core.Class\")",
                "local LuaBehaviour = require(\"Core.LuaBehaviour\")",
                "",
                "local TestTable, super = Class(\"TestTable\", LuaBehaviour)",
                "",
                "function TestTable:__Define()",
                "\tself.transform = CSType.Transform",
                "\tself.int = CSType.Int32",
                "\tself.v = CSType.Vector3",
                "end",
                "",
                "return TestTable"
            ]
        },
        { "type": "header", "level": 4, "data": "CSType.lua举例" },
        {
            "type": "code",
            "data": [
                "local CSE = CS.UnityEngine",
                "local CSO = CS.System",
                "",
                "---@class CSType",
                "local CSType = {}",
                "setmetatable(CSType, {",
                "\t__index = function (t, k)",
                "\t\tif k == nil then",
                "\t\t\tprint(\"<color=red>Error Type</color>\", t, k)",
                "\t\tend",
                "\t\tt[k] = typeof(k)",
                "\t\treturn rawget(t, k)",
                "\tend",
                "})",
                "",
                "CSType.Transform = CSType[CSE.Transform]",
                "CSType.Int32 = CSType[CSO.Int32]",
                "CSType.Vector3 = CSType[CSE.Vector3]",
                "",
                "return CSType"
            ]
        },
        { "type": "header", "level": 4, "data": "LuaBehaviour.cs中相关" },
        {
            "type": "text",
            "data": [
                "1. 以UnityEngine.Object的序列化为例，声明可序列化的类ObjectWrap",
                "2. name 为变量名称",
                "3. typeName 为该变量的类型",
                "4. assembly 为该类型所在的库，因为需要使用反射进行序列化"
            ]
        },
        {
            "type": "code",
            "data": [
                "[LuaCallCSharp]",
                "public class LuaBehaviour : MonoBehaviour",
                "{",
                "\t[Serializable]",
                "\tpublic class ObjectWrap",
                "\t{",
                "\t\tpublic string name;",
                "\t\tpublic UnityEngine.Object obj;",
                "\t\tpublic string typeName;",
                "\t\tpublic string assembly;",
                "\t}",
                "",
                "\tpublic DefaultAsset luaScript;",
                "",
                "\tpublic string requirePath;",
                "",
                "\t[SerializeField]",
                "\tpublic List<ObjectWrap> objects;",
                "}"
            ]
        },
        { "type": "header", "level": 4, "data": "LuaBehaviourInspector.cs中相关" },
        {
            "type": "code",
            "data": [
                "[CustomEditor(typeof(GameCore.LuaBehaviour), true)]",
                "public class LuaBehaviourInspector : Editor",
                "{",
                "",
                "\tprivate GameCore.LuaBehaviour behaviour;",
                "",
                "\tvoid OnEnable()",
                "\t{",
                "\t\tbehaviour = target as GameCore.LuaBehaviour;",
                "\t}",
                "",
                "\tvoid LoadLua()",
                "\t{",
                "\t\tif(behaviour.objects != null)",
                "\t\t{",
                "\t\t    behaviour.objects.Clear();",
                "\t\t}",
                "\t\t// 当然这里还可以遍历前面已经序列化后的变量，不将所有的变量初始化，保留上次序列化后的参数",
                "\t\t// 这里因为篇幅就没写",
                "\t\tbehaviour.objects = new List<GameCore.LuaBehaviour.ObjectWrap>();",
                "",
                "\t\tif (behaviour.luaScript != null)",
                "\t\t{",
                "\t\t\tstring path = AssetDatabase.GetAssetPath(behaviour.luaScript).Replace('\\', '/');",
                "\t\t\tstring luaDir = \"Assets/Scripts/Lua/\";",
                "\t\t\tstring requirePath = path.Substring(luaDir.Length).Remove(\".lua\").Replace('/', '.');",
                "\t\t\tstring cmd = string.Format(\"local t = require('{0}'); return t;\", requirePath);",
                "\t\t\tobject[] r = ProjectLuaEnv.Instance.DoString(cmd);",
                "",
                "\t\t\tLuaTable table = (LuaTable)r[0];",
                "\t\t\tLuaFunction action = table.Get<LuaFunction>(\"Define\");",
                "\t\t\taction?.Call(table);   // C# 还是按照Lua的方式访问函数",
                "\t\t\tLuaTable defineList = table.Get<LuaTable>(\"_DefineList\");",
                "",
                "\t\t\tfor(int i = 1; i <= defineList.Length; i++)",
                "\t\t\t{",
                "\t\t\t\tLuaTable t = defineList.Get<object, LuaTable>(i);",
                "\t\t\t\tstring name = t.Get<string>(\"name\");",
                "\t\t\t\tType type = t.Get<Type>(\"type\");",
                "\t\t\t\tif (type.IsSubclassOf(typeof(UnityEngine.Object)))",
                "\t\t\t\t{",
                "\t\t\t\t\tbehaviour.objects.Add(new GameCore.LuaBehaviour.ObjectWrap()",
                "\t\t\t\t\t{",
                "\t\t\t\t\t\tname = name,",
                "\t\t\t\t\t\ttypeName = type.FullName,",
                "\t\t\t\t\t\tassembly = Assembly.GetAssembly(type).GetName().Name,",
                "\t\t\t\t\t});",
                "\t\t\t\t}",
                "\t\t\t\telse",
                "\t\t\t\t{",
                "\t\t\t\t\t// 这里写值类型的 直接参考blueberryzzz里面的方法，此部分不做赘述",
                "\t\t\t\t}",
                "            ",
                "\t\t\t}",
                "\t\t\ttable.Dispose();",
                "\t\t\tdefineList.Dispose();",
                "\t\t\taction.Dispose();",
                "\t\t\tProjectLuaEnv.Instance.Dispose();",
                "\t\t}",
                "\t\tbehaviour.Rebuild();",
                "\t}",
                "",
                "\tpublic override void OnInspectorGUI()",
                "\t{",
                "\t\t//base.OnInspectorGUI();",
                "\t\tserializedObject.Update();",
                "\t\t//绘制Lua路径",
                "\t\tif(GUILayout.Button(\"Load Lua\"))",
                "\t\t{",
                "\t\t\tLoadLua();",
                "\t\t}",
                "\t\tif (GUILayout.Button(\"Save\"))",
                "\t\t{",
                "\t\t\tbehaviour.Rebuild();",
                "\t\t}",
                "\t\tbehaviour.luaScript = EditorGUILayout.ObjectField(\"Lua Script\", behaviour.luaScript, typeof(DefaultAsset)) as DefaultAsset;",
                "\t\tEditorGUILayout.LabelField(\"Require Path\", behaviour.requirePath);",
                "\t\tif(behaviour.objects != null)",
                "\t\t{",
                "\t\t\tfor(int i = 0; i < behaviour.objects.Count; i++)",
                "\t\t\t{",
                "\t\t\t\tGameCore.LuaBehaviour.ObjectWrap wrap = behaviour.objects[i];",
                "\t\t\t\twrap.obj = EditorGUILayout.ObjectField(wrap.name, wrap.obj, Assembly.Load(\"UnityEngine\").GetType(wrap.typeName));",
                "\t\t\t}",
                "\t\t}",
                "\t\tserializedObject.ApplyModifiedProperties();",
                "\t}",
                "}"
            ]
        },
